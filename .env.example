# ──────────────────────────────────────────────────────────
#  Les Jus Naturels Ben's — Variables d'environnement
#  Copier ce fichier en ".env" et remplir les valeurs
# ──────────────────────────────────────────────────────────

# ──────────────────────────────────────────────────────────
# SUPABASE AUTH & DATABASE
# ──────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ──────────────────────────────────────────────────────────
# CAPTCHA (Choose one: hCaptcha recommended)
# ──────────────────────────────────────────────────────────
# hCaptcha - https://www.hcaptcha.com
VITE_HCAPTCHA_SITE_KEY=your-hcaptcha-site-key

# OR reCAPTCHA v3 - https://www.google.com/recaptcha
VITE_RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# ──────────────────────────────────────────────────────────
# PAYMENT PROCESSING
# ──────────────────────────────────────────────────────────
# Square - https://dashboard.square.com/apps
VITE_SQUARE_APP_ID=your-square-app-id
VITE_SQUARE_LOCATION_ID=your-square-location-id

# ──────────────────────────────────────────────────────────
# EMAIL SERVICE (Backend only)
# ──────────────────────────────────────────────────────────
# Supabase Email or SendGrid
SUPABASE_SERVICE_KEY=your-service-key
SENDGRID_API_KEY=your-sendgrid-key-optional

# ──────────────────────────────────────────────────────────
# MONITORING & LOGGING
# ──────────────────────────────────────────────────────────
# For analytics (optional)
VITE_ANALYTICS_ID=your-analytics-id
VITE_SENTRY_DSN=your-sentry-dsn-optional

# ──────────────────────────────────────────────────────────
# APP CONFIG
# ──────────────────────────────────────────────────────────
VITE_APP_URL=https://lesjusnatrelsbens.com
VITE_API_URL=https://api.lesjusnatrelsbens.com
VITE_ENV=production
